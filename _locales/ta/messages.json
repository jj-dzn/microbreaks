    "message": "3 விநாடிகள் பிடித்து, விடுங்கள், 5 முறை மீண்டும் செய்யவும்"
  },
  "stretchUpperBackSqueeze": {
    "message": "மேல் முதுகு இறுக்கம்"
  },
  "stretchUpperBackSqueezeDesc": {
    "message": "முழங்கைகளை பின்னோக்கி இழுத்து தோள்பட்டைகளை உறுதியாக நெருக்கவும்."
  },
  "stretchUpperBackSqueezeStep1": {
    "message": "நேராக உட்காரவும், கைகள் பக்கங்களில்"
  },
  "stretchUpperBackSqueezeStep2": {
    "message": "முழங்கைகளை 90 டிகிரியில் வளைக்கவும்"
  },
  "stretchUpperBackSqueezeStep3": {
    "message": "இரு முழங்கைகளையும் உடலுக்குப் பின்னால் இழுக்கவும்"
  },
  "stretchUpperBackSqueezeStep4": {
    "message": "தோள்பட்டைகளை உறுதியாக நெருக்கவும்"
  },
  "stretchUpperBackSqueezeStep5": {
    "message": "5 விநாடிகள் பிடித்து, விடுங்கள், 5 முறை மீண்டும் செய்யவும்"
  },
  "stretchTempleMassage": {
    "message": "நெற்றி பக்க மசாஜ்"
  },
  "stretchTempleMassageDesc": {
    "message": "பதற்றத்தைத் தளர்த்த நெற்றி பக்கங்களில் மெதுவான வட்ட அழுத்தம் கொடுக்கவும்."
  },
  "stretchTempleMassageStep1": {
    "message": "உங்கள் விரல் நுனிகளை நெற்றி பக்கங்களில் வைக்கவும்"
  },
  "stretchTempleMassageStep2": {
    "message": "உள்நோக்கி மெதுவான வட்ட அழுத்தம் கொடுக்கவும்"
  },
  "stretchTempleMassageStep3": {
    "message": "சிறிய வட்டங்களில் மெதுவாக நகரவும்"
  },
  "stretchTempleMassageStep4": {
    "message": "ஆழமாக சுவாசித்து தாடை பதற்றத்தை விடவும்"
  },
  "stretchTempleMassageStep5": {
    "message": "முழு 20 விநாடிகளும் தொடரவும்"
  },
  "stretchAnkleCircles": {
    "message": "கணுக்கால் சுழற்சி"
  },
  "stretchAnkleCirclesDesc": {
    "message": "இரத்த ஓட்டத்தை மேம்படுத்த கால்களை தூக்கி கணுக்கால்களை மெதுவாக சுழற்றவும்."
  },
  "stretchAnkleCirclesStep1": {
    "message": "கால்களை தரையிலிருந்து தூக்கி உட்காரவும்"
  },
  "stretchAnkleCirclesStep2": {
    "message": "கால் விரல்களை மெதுவாக முன்னோக்கி நேராக்கவும்"
  },
  "stretchAnkleCirclesStep3": {
    "message": "இரு கணுக்கால்களையும் மெதுவாக வெளியே சுழற்றவும்"
  },
  "stretchAnkleCirclesStep4": {
    "message": "5 சுற்றுகளை முடித்து திசையை மாற்றவும்"
  },
  "stretchAnkleCirclesStep5": {
    "message": "முடிக்க கால்களை வளைத்து நேராக்கவும்"
  },
  "stretchFingerSpreads": {
    "message": "விரல் விரிப்பு"
  },
  "stretchFingerSpreadsDesc": {
    "message": "தட்டச்சு பதற்றத்தை குறைக்க விரல்களை அகலமாக விரித்து, பின் முஷ்டியாக மடிக்கவும்."
  },
  "stretchFingerSpreadsStep1": {
    "message": "இரு கைகளையும் உங்கள் முன்னே நீட்டவும்"
  },
  "stretchFingerSpreadsStep2": {
    "message": "விரல்களை முடிந்தவரை அகலமாக விரிக்கவும்"
  },
  "stretchFingerSpreadsStep3": {
    "message": "3 விநாடிகள் விரிப்பை தக்கவைக்கவும்"
  },
  "stretchFingerSpreadsStep4": {
    "message": "பின் விரல்களை தளர்வான முஷ்டியாக மடிக்கவும்"
  },
  "stretchFingerSpreadsStep5": {
    "message": "திறத்தல்-மூடுதல் இயக்கத்தை 5 முறை மீண்டும் செய்யவும்"
  },
  "stretchHipStretch": {
    "message": "இடுப்பு ஸ்ட்ரெச்"
  },
  "stretchHipStretchDesc": {
    "message": "இடுப்பு மற்றும் குறுக்குத் தசையை நீட்ட ஒரு முழங்காலை மார்புக்கு தூக்கவும்."
  },
  "stretchHipStretchStep1": {
    "message": "சமநிலைக்காக உங்கள் மேசையை அருகே நிற்கவும்"
  },
  "stretchHipStretchStep2": {
    "message": "வலது முழங்காலை மார்புக்கு தூக்கவும்"
  },
  "stretchHipStretchStep3": {
    "message": "இரு கைகளாலும் மெதுவாக பிடிக்கவும்"
  },
  "stretchHipStretchStep4": {
    "message": "இடுப்பு மற்றும் குறுக்குத் தசையில் நீட்சியை உணரவும்"
  },
  "stretchHipStretchStep5": {
    "message": "3 மூச்சு பிடித்து கால் மாற்றவும்"
  },
